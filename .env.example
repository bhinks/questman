# =====================================================================
# Questman — environment file.
#
# Copy to .env and edit values you care about. Variables left unset
# get the defaults baked into docker-compose.yml.
#
#   cp .env.example .env
#   docker compose up --build
#
# Reach the app at http://localhost:8080 once both containers are up.
# =====================================================================

# ----- Required -------------------------------------------------------

# JWT signing secret. Must be 32+ chars in production — short secrets
# make tokens trivial to forge. Generate one with:
#   openssl rand -base64 48
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_OF_AT_LEAST_32_CHARS"

# ----- Recommended ----------------------------------------------------

# Your own login. If both are set, the seed creates this account on
# first boot (idempotent — re-runs don't reset the password). Without
# these, only the seeded demo account (demo@questman.app / demo123) can
# log in. The demo account always exists; you can ignore it if you
# provision your own user.
HUB_USER_EMAIL="you@example.com"
HUB_USER_PASSWORD="change_me_at_least_8_chars"
HUB_USER_NAME="You"

# Timezone. All day-based constraints (quest dates, habit completions,
# streaks) compute "local midnight" in this TZ. Use your real local TZ
# or daily quests will roll over at the wrong time.
#   e.g. "America/New_York", "Europe/Berlin", "Asia/Tokyo"
TZ="UTC"

# ----- AI quest generation (optional) --------------------------------

# ALL AI features ship DISABLED and are enabled in-app: SYS // CALIBRATION
# → AI Calibration (master switch, feature toggles, per-domain data
# grants). This key alone turns nothing on — it just makes the Anthropic
# cloud provider available once you opt in. Without it (and without a
# local Ollama node), the quest engine uses the rule-based fallback
# (themed names from a fixed list, no model calls).
#   https://platform.claude.com/
ANTHROPIC_API_KEY=""

# Default is claude-opus-4-8 (most capable). For lighter usage:
#   claude-haiku-4-5  — fastest + cheapest, fine for quest theming.
#   claude-sonnet-4-6 — middle tier.
ANTHROPIC_MODEL="claude-opus-4-8"

# Set to "false" to force the rule-based fallback even when an API key
# is set (useful for offline use or to save tokens).
AI_QUESTS="true"

# ----- Weather-aware chores (optional) -------------------------------

# Your hub's location, used to gate outdoor chores/habits (e.g. "mow
# the lawn" only when it's dry, warm, and not too windy) and to pick
# the best time-of-day window for them. Uses Open-Meteo — no API key,
# free. Both must be set; if either is missing, outdoor habits fall
# back to interval-only gating (no weather check). Decimal degrees.
#   e.g. New York: 40.71 / -74.01   Berlin: 52.52 / 13.40
HUB_LAT=""
HUB_LON=""

# ----- Calendar uplink (optional) ------------------------------------

# Private ICS feed URL(s), comma-separated. With this set, today's
# calendar busy-time shrinks the day planner's "go" budget, and the
# Today page shows a GRID SCHEDULE agenda panel. Read-only. The AI only
# sees it if you open the GRID SCHEDULE grant in AI Calibration (off by
# default) — and even then only counts and free/busy, never titles.
#
# Google Calendar: Settings → your calendar → "Integrate calendar" →
# "Secret address in iCal format". Treat the URL like a password.
CALENDAR_ICS_URL=""

# ----- Health ingest (optional) ---------------------------------------

# Shared secret for the /api/ingest/* endpoints. 16+ chars; generate:
#   openssl rand -hex 24
# Two receivers:
#   /api/ingest/health-connect?token=<this>  — native receiver for the
#     health-connect-webhook Android app (Pixel Watch / Health Connect →
#     steps, sleep, resting HR, weight, BP, hydration). Token goes in
#     the URL because the app can't set custom headers.
#   /api/ingest/metrics — generic {entries:[{date,key,value}]} bulk
#     upserts; token via the X-Ingest-Token header (or ?token=).
# Unset = both endpoints only accept a logged-in JWT.
INGEST_TOKEN=""

# Health PULL mode — the recommended route when your hub is plain HTTP:
# Android's cleartext policy blocks the webhook app from POSTing to an
# http:// URL, but the same app's "Local HTTP Server" mode (GET-only,
# trusted LAN, port 8787 by default) works fine the other way around.
# Set this to the phone's address and the backend polls it on a schedule
# (give the phone a DHCP reservation in your router so the IP is stable).
#   e.g. HEALTH_PULL_URL="http://192.168.0.42:8787"
HEALTH_PULL_URL=""
HEALTH_PULL_MINUTES="30"

# How many days of history to request on the first successful pull after
# boot, to backfill the trend charts (steady-state polls stay incremental).
# Up to ~10y (3650); the phone returns only as much as Health Connect retains.
HEALTH_BACKFILL_DAYS="365"

# The app's "Local HTTP auth" bearer token (shown in its settings).
# Recommended: with auth off, the phone's health server answers anyone
# on your LAN. Sent as "Authorization: Bearer <token>" on every poll.
HEALTH_PULL_TOKEN=""

# ----- Media estimation (optional) -----------------------------------
#
# Powers the Braindance/Media planner's AUTO-ESTIMATE: page counts, episode
# counts + per-episode runtime, movie runtimes, and game time-to-beat. All
# sources degrade gracefully to manual entry when unset/unreachable.
#
# Books: Open Library — KEYLESS, nothing to configure here.
#
# Movies + Shows: TMDb. Free key from https://www.themoviedb.org/settings/api
# (the v3 API key). Without it, movie/show auto-estimate falls back to manual.
TMDB_API_KEY=""
#
# Games: IGDB (the reliable, documented source — main-story time-to-beat).
# IGDB auth is a free Twitch app: https://dev.twitch.tv/console/apps → create
# an app → copy the Client ID + generate a Client Secret. Without these, games
# fall back to a best-effort HowLongToBeat lookup, then to manual entry.
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ----- Steam integration (optional) ---------------------------------
#
# Syncs your Steam game library (owned games + playtime) so you can:
#   1. See how many hours you've spent gaming recently (cutback view).
#   2. Browse unplayed games and add them to the Braindance media queue.
#
# STEAM_API_KEY: free key from https://steamcommunity.com/dev/apikey
#   (register any app name; only the key matters).
# STEAM_USER_ID: your Steam64 account ID — find it at https://steamid.io
#   (paste your profile URL; copy the steamID64 value).
# Your game details visibility must be set to Public in Steam privacy settings.
# Sync is manual: STEAM tab → SYNC LIBRARY button.
STEAM_API_KEY=""
STEAM_USER_ID=""

# ----- Multi-user & admin (optional) ---------------------------------

# Allow new users to self-register (POST /api/auth/register). Off by
# default — the admin creates users via /api/admin/users. The first user
# to register (when the DB is empty) always gets admin role regardless.
ALLOW_REGISTRATION="false"

# Service-to-service admin key. When set, requests to /api/admin/*
# carrying "X-Admin-Key: <value>" are accepted without a browser session.
# Use this to let NovaHQ (or any trusted service) manage Questman users.
# Generate: openssl rand -hex 24   (must be 16+ chars)
ADMIN_API_KEY=""

# ----- Networking ----------------------------------------------------

# Host port the SPA is exposed on. Change if 8080 collides.
WEB_PORT="8080"

# Token lifetime. Default 30d for a self-hosted hub (no need for the
# tighter 7d default from the backend's stricter dev config).
JWT_EXPIRES_IN="30d"
