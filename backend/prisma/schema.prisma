// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions         Transaction[]
  categories           Category[]
  vendors              Vendor[]
  categoryRules        CategoryRule[]
  categorizationRules  CategorizationRule[]
  imports              Import[]
  analytics            Analytics[]
  settings             UserSettings?

  // Life-hub relations (additive)
  modules              Module[]
  goals                Goal[]
  habits               Habit[]
  habitCompletions     HabitCompletion[]
  workoutSessions      WorkoutSession[]
  playerProfile        PlayerProfile?
  quests               Quest[]
  questCompletions     QuestCompletion[]
  xpLedger             XpLedger[]
  walletLedger         WalletLedger[]
  dailyQuestRuns       DailyQuestRun[]

  // New quest pools (phase 2)
  projects             Project[]
  mediaItems           MediaItem[]
  dailyMetrics         DailyMetric[]
  metricDefs           MetricDef[]
  npcs                 Npc[]

  // Economy & rewards (phase 4)
  purchases            Purchase[]
  achievements         UserAchievement[]

  // World mechanics (phase 5)
  bosses               Boss[]
  questChains          QuestChain[]

  // Intelligence layer (phase 6): AI Handler + insights + weekly debrief
  handlerMessages      HandlerMessage[]
  insights             Insight[]
  weeklyReviews        WeeklyReview[]

  // Finance depth (phase 7): recurring bills / subscription audit
  recurringExpenses    RecurringExpense[]

  // Weekly workout plan (phase 8)
  workoutPlans         WorkoutPlan[]

  // Focus timer (phase 9): persisted JACK IN sessions
  focusSessions        FocusSession[]

  @@map("users")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Preferences
  currency           String  @default("USD")
  dateFormat         String  @default("MM/dd/yyyy")
  theme              String  @default("cyberpunk")
  autoCategoriztion  Boolean @default(true)
  notifications      Boolean @default(true)

  // Privacy
  dataRetention      Int     @default(365) // days
  shareAnalytics     Boolean @default(false)

  // Day-planner time budget (minutes of "go" available). Brent's
  // defaults: 4h on weekdays, 10h on weekends. The planner fits a
  // ranked quest set inside this; the user only gets suggestions of
  // WHAT to do, never WHEN (roadmap §5).
  weekdayBudgetMin   Int     @default(240)
  weekendBudgetMin   Int     @default(600)

  // Intelligence layer (phase 6): the AI Handler persona. A configurable
  // character that narrates the day (Brent picked "sardonic rogue AI").
  // handlerEnabled gates the daily-rundown/debrief narration entirely.
  handlerPersona     String  @default("rogue_ai") // "rogue_ai"|"fixer"|"ripperdoc"
  handlerEnabled     Boolean @default(true)

  // AI Calibration (SYS//CAL): the user owns every AI decision. AI is flavor,
  // never load-bearing — everything below only narrows what the optional LLM
  // layer may do and see. aiEnabled is the master breaker: off = zero LLM
  // calls anywhere. The access grants control which data domains may be sent
  // to the model (quest candidates, digest lines, insight re-voicing).
  aiEnabled          Boolean @default(true)
  aiQuestsEnabled    Boolean @default(true)  // AI-selected + themed daily quests
  aiAccessFinance    Boolean @default(true)  // Vault: transactions, budgets, bills
  aiAccessHealth     Boolean @default(true)  // Vitals + Workouts
  aiAccessSocial     Boolean @default(true)  // Social: contacts/NPCs
  // Calendar defaults SEALED: unlike the three above, it never flowed to
  // the AI before this grant existed, so off preserves prior behavior.
  aiAccessCalendar   Boolean @default(false) // ICS agenda: counts, times, free/busy
  aiProvider         String  @default("anthropic") // "anthropic" | "ollama"
  aiModelQuests      String?                 // cloud model override (null = server default)
  aiModelHandler     String?                 // cloud model override (null = server default)
  ollamaUrl          String  @default("http://localhost:11434")
  ollamaModel        String  @default("llama3.1")
  aiDailyTokenCap    Int     @default(100000) // tokens/day, all calls; 0 = unlimited
  aiTokensUsed       Int     @default(0)      // running total for aiTokensUsedOn's day
  aiTokensUsedOn     DateTime?                // local-midnight day the counter covers

  // Night City display calibration (design handoff): the three user-tunable
  // "CRT character" knobs, persisted per user and applied as CSS vars on the
  // app root. Defaults are the design owner's reviewed baselines. (The old
  // tickerEnabled knob was retired — handlerEnabled owns handler visibility.)
  displayCut         Int     @default(24)   // panel corner clip, 0–28px
  displayChroma      Float   @default(2)    // chroma-split offset, 0–4px
  displayCrt         Int     @default(75)   // CRT intensity %, 0–100 → scan/sweep alphas

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Core transaction data
  date        DateTime
  description String
  amount      Float     // Negative for expenses, positive for income
  
  // Categorization
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  vendorId    String?
  vendor      Vendor?   @relation(fields: [vendorId], references: [id])
  
  // Metadata
  originalDescription String? // Original before any processing
  confidence  Float?    // AI categorization confidence (0-1)
  isManual    Boolean   @default(false) // User manually edited
  isRecurring Boolean   @default(false)
  
  // Analysis flags
  isWasteful  Boolean   @default(false)
  isSuspicious Boolean  @default(false)

  // Finance depth: exclude this row from ALL totals/charts/insights — for
  // inter-account transfers and other noise. Reversible + non-destructive
  // (the row stays visible, greyed); the analyzer/analytics/digest skip it.
  excluded    Boolean   @default(false)

  // Optional links: the project and/or chore this spend belongs to (one each,
  // per Brent). Enables per-project / per-chore spend rollups. SetNull so
  // deleting the project/chore doesn't delete the transaction history.
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  choreId     String?
  chore       Habit?    @relation("ChoreTransactions", fields: [choreId], references: [id], onDelete: SetNull)

  // Import tracking
  importId    String?
  import      Import?   @relation(fields: [importId], references: [id])
  
  // Source account ("checking", "amex", …) — captured from the optional
  // Account column on import. A filter dimension only; NO account
  // integration, balances, or sync (per Brent).
  account     String?

  // Notes and tags
  notes       String?
  tags        String?   // JSON array of tags
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("transactions")
  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, amount])
  @@index([userId, excluded])
  @@index([projectId])
  @@index([choreId])
}

model Category {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  icon        String?
  color       String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  // Metadata
  isSystem    Boolean   @default(false) // Built-in categories
  isActive    Boolean   @default(true)
  
  // Budgeting
  budget Float?
  
  // Relations
  transactions Transaction[]
  rules        CategoryRule[]
  recurringExpenses RecurringExpense[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, name])
  @@map("categories")
}

model Vendor {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  aliases     String? // JSON array of alternative names
  website     String?
  categoryId  String? // Default category for this vendor
  
  // Metadata
  isActive    Boolean @default(true)
  frequency   Float?  // Average transactions per month
  
  // Relations
  transactions Transaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@map("vendors")
}

model CategoryRule {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Rule definition
  keywords   String  // JSON array of keywords
  conditions String? // JSON object for advanced conditions
  priority   Int     @default(0)
  
  // Metadata
  isActive   Boolean @default(true)
  confidence Float   @default(0.8)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("category_rules")
  @@index([userId, priority])
}

model Import {
  id              String @id @default(cuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  filename        String
  originalName    String
  fileSize        Int
  format          String  // csv, xlsx, etc.
  
  // Processing results
  totalRows       Int
  processedRows   Int
  errorRows       Int
  duplicateRows   Int
  
  // Status
  status          String  // pending, processing, completed, failed
  errorMessage    String?
  
  // Relations
  transactions    Transaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("imports")
  @@index([userId, createdAt])
}

model WastefulPattern {
  id            String   @id @default(cuid())
  userId        String
  
  type          String   // frequent_small, large_discretionary, etc.
  description   String
  amount        Float
  frequency     Float?
  confidence    Float    @default(0.5)
  
  // Pattern data
  transactionIds String  // JSON array of transaction IDs
  metadata       String? // JSON object for pattern-specific data
  
  // Status
  isActive       Boolean  @default(true)
  isAcknowledged Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("wasteful_patterns")
  @@index([userId, type])
}

model CategorizationRule {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name       String
  conditions String // JSON object for rule conditions
  actions    String // JSON object for rule actions
  priority   Int    @default(100)
  isActive   Boolean @default(true)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("categorization_rules")
  @@index([userId, priority])
}

model Analytics {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Time period
  period   String   // daily, weekly, monthly, yearly
  date     DateTime
  
  // Metrics
  metrics  String   // JSON object with all calculated metrics
  
  createdAt DateTime @default(now())
  
  @@unique([userId, period, date])
  @@map("analytics")
  @@index([userId, date])
}

// =====================================================================
// Life-hub additions: modules, goals, habits/chores, workouts,
// gamification (player profile, quests, XP ledger, daily-run lock).
// All scoped by userId; JSON stored as String for SQLite portability.
// =====================================================================

model Module {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key       String   // "finance" | "fitness" | "habits" | "chores"
  name      String
  icon      String?
  color     String?  // CSS var name or hex (drives the nav accent)
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  config    String?  // JSON: module-specific settings

  goals     Goal[]
  habits    Habit[]
  workouts  WorkoutSession[]
  quests    Quest[]
  projects  Project[]
  mediaItems MediaItem[]
  npcs      Npc[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@map("modules")
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  metric       String   // "count" | "minutes" | "currency" | "boolean" | "distance"
  targetValue  Float?
  currentValue Float    @default(0)
  unit         String?
  period       String   @default("ongoing") // "daily"|"weekly"|"monthly"|"ongoing"
  status       String   @default("active")  // "active"|"completed"|"archived"
  dueDate      DateTime?

  // Links a goal back to a domain entity it tracks (no FK; loose pointer).
  sourceType   String?  // "habit"|"category"|"wastefulPattern"
  sourceId     String?

  quests       Quest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, moduleId])
  @@index([userId, status])
  @@map("goals")
}

model Habit {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId        String
  module          Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  kind            String   @default("habit") // "habit" | "chore"
  // Direction of the trackable: "do" = a positive habit/chore you complete;
  // "avoid" = an anti-goal / ICE (you stay clean and log only SLIPS). Avoid
  // habits don't generate "do this" quests; clean days auto-credit at the
  // daily roll-over and currentStreak is the avoidance streak.
  polarity        String   @default("do") // "do" | "avoid"
  title           String
  description     String?
  icon            String?
  color           String?

  // Recurrence. One-off chores use cadence="once" + dueDate.
  cadence         String   @default("daily") // "daily"|"weekly"|"custom"|"once"
  schedule        String?  // JSON: {daysOfWeek:[1,3,5]} or {everyN:2}
  dueDate         DateTime?
  targetPerDay    Int      @default(1)

  // Gamification tuning
  baseXp          Int      @default(10)
  difficulty      String   @default("easy") // "easy"|"medium"|"hard"
  isActive        Boolean  @default(true)

  // Estimated time-to-complete in minutes. Foundational for the day
  // planner (roadmap §5) — flows into generated quests so the engine
  // can fit a set inside a daily time budget. Optional; null = unknown.
  estMinutes      Int?

  // Optional throttling: minimum days between completions. Independent
  // of cadence — "weekly" with minInterval=4 means weekly schedule but
  // skip if done <4 days ago.
  minIntervalDays Int?

  // Optional outdoor / weather gating, evaluated by WeatherService +
  // QuestEngine. US units. JSON shape:
  //   { outdoor: true, dryDaysRequired?: 2, maxRainTodayIn?: 0.1,
  //     minTempF?: 40, maxTempF?: 95, maxWindMph?: 20 }
  // When weather data is unavailable (no HUB_LAT/HUB_LON set, API
  // down), the gate degrades to interval-only.
  weatherRule     String?

  // Denormalized streak (also reconstructable from completions).
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastCompletedOn DateTime?

  completions     HabitCompletion[]
  quests          Quest[]
  choreTransactions Transaction[] @relation("ChoreTransactions") // finance depth: spend linked to this chore

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, kind, isActive])
  @@map("habits")
}

model HabitCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  // Date-at-local-midnight (server-computed). Backbone of idempotency.
  completedOn DateTime
  count       Int      @default(1)
  note        String?
  xpAwarded   Int      @default(0)
  // Actual eddies banked for this check (already overclock-multiplied).
  // Undo reverses THIS exact amount — never a recomputed raw value — so a
  // check+undo cycle nets zero even when the overclock multiplier was active.
  eddiesAwarded Int    @default(0)
  source      String   @default("manual") // "manual"|"quest"

  createdAt   DateTime @default(now())

  @@unique([habitId, completedOn])
  @@index([userId, completedOn])
  @@map("habit_completions")
}

// A weekly workout TEMPLATE entry ("push day every Monday"). Brent lays the
// plan out once; each week the planned slot for today feeds a specific quest
// candidate and pre-fills the logger. Actuals are still WorkoutSessions —
// the plan is the intention, the session is the receipt.
model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayOfWeek   Int      // 0=Sunday .. 6=Saturday (JS Date.getDay convention)
  title       String   // "Push day", "Long run"
  type        String   @default("strength") // mirrors WorkoutSession.type
  targetMin   Int?     // intended duration
  notes       String?  // "bench/OHP/dips"
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, dayOfWeek])
  @@map("workout_plans")
}

model WorkoutSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title       String?
  type        String   // "strength"|"cardio"|"mobility"|"sport"|"other"
  performedAt DateTime
  durationMin Int?
  intensity   String?  // "low"|"moderate"|"high"
  caloriesEst Int?
  notes       String?

  // Structured detail as JSON-string (SQLite-friendly):
  // e.g. [{exercise:"Bench",sets:[{reps:8,weight:60},...]}, ...]
  exercises   String?  // JSON
  metrics     String?  // JSON: {distanceKm, avgHr, ...}

  xpAwarded   Int      @default(0)

  // Idempotency key from the client (one per Log-Workout form). A double-
  // submit/retry reuses it and collides on the unique index below, so the
  // duplicate is a no-op instead of a second XP/eddie payout. NULL is allowed
  // and (SQLite) distinct, so unkeyed logs and intentional separate sessions
  // are never deduped.
  clientRequestId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, clientRequestId])
  @@index([userId, performedAt])
  @@map("workout_sessions")
}

// A finished focus-timer run (the JACK IN deep-work chamber). Persisted on
// jack-out; the timer itself is client-side. Time accumulates against the
// chosen target so views can show ACTUAL minutes spent per object.
model FocusSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What the time was spent on: "quest"|"project"|"habit"|"chore"|"workout"|"other".
  // habit/chore both reference Habit rows (kind distinguishes); workout
  // references a WorkoutPlan; targetId is null for "other". label is a
  // display-title snapshot (freeform text for "other") so the log still
  // reads after the target is deleted/expired.
  targetType   String   @default("other")
  targetId     String?
  label        String

  startedAt    DateTime
  endedAt      DateTime
  minutes      Int      // rounded wall-clock actual
  limitMinutes Int?     // countdown limit chosen at start; null = open-ended count-up

  createdAt    DateTime @default(now())

  @@index([userId, startedAt])
  @@index([userId, targetType, targetId])
  @@map("focus_sessions")
}

model PlayerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  level         Int      @default(1)
  totalXp       Int      @default(0)
  xpIntoLevel   Int      @default(0)   // cached; derivable from level + totalXp
  // Spendable currency (Eddies, €$). Cached running balance; the
  // authoritative value is the sum of WalletLedger entries. XP is
  // permanent progression, eddies are earned-and-spent (roadmap economy).
  eddies        Int      @default(0)
  currentStreak Int      @default(0)   // global daily-activity streak

  // --- Economy & rewards (phase 4) ---
  // Consecutive FULL-CLEAR days. Drives the "overclock" eddie multiplier
  // (1.0–2.0). Bumped/reset in QuestEngine.ensureToday by evaluating
  // whether the previous day was fully cleared. A miss (an expired quest)
  // resets it; this is the "cooling unstable" heat meter.
  overclockStreak Int    @default(0)
  // Burnout-relief tokens. skip = drop a quest with no penalty; reroll =
  // swap a quest for a different one. A free weekly allowance is granted
  // in ensureToday; extras are bought in the Shop.
  skipTokens    Int      @default(3)
  rerollTokens  Int      @default(1)
  // R&R / downtime credits — earned on clean days + achievements, spent to
  // start a guilt-free media session (earn your downtime).
  rrCredits     Int      @default(0)
  // --- Shop consumables (Night Market expansion) ---
  // Streak Shields: each absorbs ONE missed day at the daily roll-over,
  // preserving the overclock streak instead of resetting it (auto-fires,
  // only when there's a streak worth saving). Capped at 3.
  streakShields Int      @default(0)
  // Overdrive Chip: 2× EDDIE earns until this instant (24h from purchase).
  // XP stays honest (Brent's rule) — only the spendable currency boosts.
  boosterUntil  DateTime?
  // Time Dilation: +2h day-planner budget for the local day stored here
  // (ignored once the day rolls over). One per day.
  budgetBoostOn DateTime?
  // ISO-week key (e.g. "2026-W24") of the last weekly token grant, so the
  // allowance refills once per week, lazily, on the first run of the week.
  lastTokenGrantWeek String?
  // Cosmetics: JSON array of unlocked cosmetic keys (themes, fonts, FX,
  // personas); equippedTheme is the active HUD palette (null = default neon).
  cosmetics     String?
  equippedTheme String?
  // Night Market expansion: independently-equippable cosmetic slots.
  equippedFont  String?  // display-font pack key (null = stock Chakra Petch)
  equippedFx    String?  // ambient FX pack key (null = none)
  equippedTimer String?  // focus-chamber timer style key (null = standard)
  // --- World mechanics (phase 5): energy / battery ---
  // A daily capacity tier derived from sleep (vitals sleepHours) with a
  // manual override. "low"|"med"|"high". energyOverrideOn pins the override
  // to a local day; it's ignored once the day rolls over (back to derived).
  energyOverride   String?
  energyOverrideOn DateTime?
  longestStreak Int      @default(0)
  lastActiveOn  DateTime?

  // Per-domain XP as JSON: {"fitness":120,"finance":80}
  domainXp      String?
  title         String?  // cosmetic rank, e.g. "Runner — Tier 2"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("player_profiles")
}

model Quest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Date-at-local-midnight for the "day" this quest belongs to.
  questDate   DateTime
  title       String     // themed name e.g. "Ghost Protocol"
  description String
  difficulty  String     @default("easy")
  xpReward    Int

  // Provenance: what generated this quest.
  source      String     // "habit"|"goal"|"workout"|"finance"|"ai"|"rule"
  sourceId    String?    // habitId / goalId / wastefulPatternId / null

  habitId     String?
  habit       Habit?     @relation(fields: [habitId], references: [id])
  goalId      String?
  goal        Goal?      @relation(fields: [goalId], references: [id])

  status      String     @default("pending") // "pending"|"completed"|"skipped"|"expired"
  target      Float      @default(1)
  progress    Float      @default(0)
  isAiThemed  Boolean    @default(false)
  meta        String?    // JSON: theming, color, emoji, generator notes

  // --- Quest-engine overhaul fields (roadmap §5) ---
  // Estimated minutes to complete — drives the day planner's time-budget fit.
  estMinutes   Int?
  // Check-in progress counter (e.g. "drink 8 glasses" → targetCount=8).
  // Normal one-shot quests keep targetCount=1. currentCount drips XP.
  targetCount  Int       @default(1)
  currentCount Int       @default(0)
  // Persistence: a carry-over quest rolls to the next day if left
  // incomplete instead of expiring. mustDo quests always carry + rank first.
  carryOver    Boolean   @default(false)
  mustDo       Boolean   @default(false)
  // The local day this quest was first generated (set on carry so the UI
  // can show "carried from <date>"); null = generated for its questDate.
  originDate   DateTime?
  // Focus-timer actuals (JACK IN/OUT) — feeds estimate accuracy over time.
  actualMinutes Int?

  completion  QuestCompletion?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Idempotency guard: one quest per (day, source, sourceId) per user.
  @@unique([userId, questDate, source, sourceId])
  @@index([userId, questDate, status])
  @@map("quests")
}

model QuestCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String   @unique
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())
  xpAwarded   Int
  meta        String?  // JSON: streakBefore/after, leveledUp, etc.

  @@index([userId, completedAt])
  @@map("quest_completions")
}

model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int      // +ve earn, -ve correction
  reason    String   // "quest_complete"|"habit_log"|"workout_log"|"streak_bonus"|"level_up"
  module    String?  // "fitness" etc., for domainXp rollups
  refType   String?  // "quest"|"habit"|"workout"
  refId     String?
  meta      String?  // JSON

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, reason])
  @@map("xp_ledger")
}

// Append-only audit of the Eddies (€$) economy — the spendable-currency
// sibling of XpLedger. Balance = SUM(amount). Earns are +ve, spends are
// -ve. Like the XP ledger, it is deletion-proof: a grant survives the
// deletion of whatever task produced it, so the wallet history is
// immutable. The server is the only minter (Claude/handler never write
// here).
model WalletLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int      // +ve earn, -ve spend/correction
  reason    String   // "quest_complete"|"habit_log"|"workout_log"|"shop_purchase"|"streak_bonus"|"undo"
  module    String?  // domain that produced the earn, for rollups
  refType   String?  // "quest"|"habit"|"workout"|"shopItem"
  refId     String?
  meta      String?  // JSON

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, reason])
  @@map("wallet_ledger")
}

model DailyQuestRun {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Date-at-local-midnight: unique guarantees one generation per day per user.
  runDate    DateTime
  generator  String   @default("rule") // "ai" | "rule" | "ai-fallback"
  questCount Int      @default(0)
  meta       String?  // JSON: prompt hash, model id, errors

  createdAt  DateTime @default(now())

  @@unique([userId, runDate])
  @@map("daily_quest_runs")
}

// =====================================================================
// New quest pools (phase 2). Each follows the existing model+route+
// candidate+UI pattern. Child rows carry a bare `userId` for query
// scoping; they cascade-delete via their parent (which cascades from
// User), so no formal User back-relation is needed on the children.
// =====================================================================

// --- Projects ("Operations" / "Gigs") -------------------------------
// Replaces the half-built Goal feature (Brent chose: Projects supersede
// Goals). A Project is a work-breakdown: tasks + milestones. Incomplete
// tasks become quest candidates; completing a milestone grants bonus XP.
model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      String   @default("active") // "active"|"paused"|"done"|"archived"
  color       String?

  tasks       ProjectTask[]
  milestones  Milestone[]
  bosses      Boss[]   // bosses whose HP is linked to this project's progress
  transactions Transaction[] // finance depth: spend linked to this project

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@map("projects")
}

model ProjectTask {
  id          String   @id @default(cuid())
  userId      String   // scoping; cascades via project
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  done        Boolean  @default(false)
  estMinutes  Int?
  priority    Int      @default(0)   // higher = surfaced first
  sortOrder   Int      @default(0)
  completedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, done])
  @@index([userId])
  @@map("project_tasks")
}

model Milestone {
  id          String   @id @default(cuid())
  userId      String   // scoping; cascades via project
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  done        Boolean  @default(false)
  dueDate     DateTime?
  bonusXp     Int      @default(50)
  sortOrder   Int      @default(0)
  completedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, done])
  @@map("milestones")
}

// --- Media & consumption backlog ("Braindance queue") ---------------
// type ∈ movie|show|game|book. estMinutes is the auto-estimated time
// commitment (TMDb runtime, HLTB main story, pages × min/page, etc.).
// For books, progress is tracked in pages (unitsDone/totalUnits) and the
// reading-speed avg is kept in metaJson (default 3 min/page until data).
model MediaItem {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  type           String   // "movie"|"show"|"game"|"book"
  title          String
  status         String   @default("backlog") // "backlog"|"active"|"done"|"dropped"

  estMinutes     Int?     // total time commitment
  totalUnits     Int?     // pages (book) / episodes (show)
  unitsDone      Int      @default(0)

  externalId     String?
  externalSource String?  // "tmdb"|"openlibrary"|"googlebooks"|"hltb"|"manual"
  coverUrl       String?
  metaJson       String?  // JSON: runtime, episodeCount, pageCount, readingMinPerPage, ...

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, type])
  @@map("media_items")
}

// --- Daily log / vitals ("Biomonitor") ------------------------------
// Flexible key/value per day. One row per (user, day, key). The metric
// SET is user-configurable via MetricDef. Water lives here (moved out of
// habits per Brent).
model DailyMetric {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime // local midnight
  key       String   // matches a MetricDef.key
  value     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, key])
  @@index([userId, key, date])
  @@map("daily_metrics")
}

model MetricDef {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key       String   // "weight"|"sleepHours"|"mood"|"water"|"workHours"|"steps"|"bpSys"|"bpDia"|"restingHr"
  label     String
  unit      String?
  kind      String   @default("number") // "number"|"scale"|"integer"
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  min       Float?
  max       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@map("metric_defs")
}

// --- Social: NPCs & relationships -----------------------------------
// Contacts ("crew / street contacts"). cadenceDays is optional; we track
// time-since-last-contact for everyone. Quests are NOT person-specific
// (Brent): a generic "reach out to someone you've neglected" candidate
// fires when any contact is overdue.
model Npc {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId      String
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  name          String
  relationship  String?  // "family"|"friend"|"partner"|"colleague"|...
  cadenceDays   Int?     // optional desired contact cadence
  lastContactOn DateTime?
  notes         String?

  interactions  Interaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("npcs")
}

model Interaction {
  id        String   @id @default(cuid())
  userId    String   // scoping; cascades via npc
  npcId     String
  npc       Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)

  date      DateTime
  minutes   Int?
  planned   Boolean  @default(false)
  note      String?

  createdAt DateTime @default(now())

  @@index([npcId, date])
  @@index([userId])
  @@map("interactions")
}

// =====================================================================
// Economy & rewards (phase 4). The shop CATALOG and the achievement
// CATALOG live in code (services/shopCatalog.ts, services/achievements.ts)
// since they're fixed; these tables record what a user has BOUGHT and
// UNLOCKED. Eddie spends are also recorded in WalletLedger (the balance
// source of truth); Purchase is the human-readable receipt log.
// =====================================================================

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemKey     String   // matches a SHOP_ITEMS catalog key
  name        String   // denormalized for the receipt log
  category    String   // "token_skip"|"token_reroll"|"rr_credit"|"cosmetic"|"loot_crate"
  priceEddies Int
  grantedJson String?  // JSON: what the purchase granted (esp. loot-crate rolls)

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@map("purchases")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key           String   // matches an ACHIEVEMENTS catalog key
  unlockedAt    DateTime @default(now())
  meta          String?  // JSON: snapshot of the metric that unlocked it

  @@unique([userId, key])
  @@index([userId])
  @@map("user_achievements")
}

// ============================================================
// World mechanics (phase 5)
// ============================================================

// A big goal framed as a boss with HP you grind down (debt/project/
// challenge) or charge up (savings). HP is a real number. Damage is dealt
// MANUALLY (you log a hit — e.g. type a debt payment) or AUTOMATICALLY when
// a linked project's milestone completes. No financial-account access: a
// debt boss's balance is a number you type. Defeating one pays out XP +
// eddies (a one-time kill-screen reward) and is idempotent (rewarded only on
// the active->defeated transition).
model Boss {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  kind            String   @default("custom") // "debt"|"savings"|"project"|"challenge"|"custom"
  // grind_down: currentValue starts at targetValue and damage reduces it;
  //             defeated at <= 0 (debt, project, challenge).
  // charge_up:  currentValue starts at 0 and contributions raise it;
  //             defeated at >= targetValue (savings).
  direction       String   @default("grind_down") // "grind_down" | "charge_up"
  targetValue     Float                            // total HP / goal
  currentValue    Float    @default(0)             // remaining HP / charged amount
  unit            String?                          // display: "$", "days", "phases", ...
  color           String?
  status          String   @default("active")      // "active"|"defeated"|"abandoned"

  // Optional auto-damage source: a project whose milestone completions chip
  // the boss down. Null = purely manual.
  linkedProjectId String?
  linkedProject   Project? @relation(fields: [linkedProjectId], references: [id], onDelete: SetNull)

  // Kill-screen payout (server-owned, granted once on defeat).
  xpReward        Int      @default(200)
  eddieReward     Int      @default(100)

  logs            BossLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  defeatedAt      DateTime?

  @@index([userId, status])
  @@map("bosses")
}

// Append-only damage/contribution log for a boss (audit + history feed).
model BossLog {
  id        String   @id @default(cuid())
  bossId    String
  boss      Boss     @relation(fields: [bossId], references: [id], onDelete: Cascade)
  userId    String   // scoping; cascades via boss

  amount    Float                  // damage dealt (grind_down) / contribution (charge_up); > 0
  note      String?
  source    String   @default("manual") // "manual" | "project_milestone"

  createdAt DateTime @default(now())

  @@index([bossId, createdAt])
  @@map("boss_logs")
}

// A linear questline: ordered steps where finishing one unlocks the next.
// The current available step enters the daily candidate pool (source:"chain",
// sourceId=stepId); completing that quest marks the step done and unlocks the
// next. Projects can be mirrored as chains, but chains are user-authored here.
model QuestChain {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      String   @default("active") // "active"|"done"|"abandoned"
  color       String?

  steps       ChainStep[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@map("quest_chains")
}

model ChainStep {
  id          String   @id @default(cuid())
  chainId     String
  chain       QuestChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  order       Int                                  // 0-based position in the chain
  title       String
  description String?
  difficulty  String   @default("medium") // "easy"|"medium"|"hard"
  xpReward    Int      @default(30)
  estMinutes  Int?
  status      String   @default("locked") // "locked"|"available"|"done"
  questId     String?  // the daily Quest generated for this step, when scheduled
  completedAt DateTime?

  @@index([chainId, order])
  @@map("chain_steps")
}

// ============================================================
// Intelligence layer (phase 6) — AI Handler, insights, weekly debrief.
//
// Design constraints (mirror the quest-theming rule): the Handler only
// NARRATES. It never mints XP/eddies and never writes the economy. All of
// these tables are derived from a SERVER-COMPUTED digest of facts the user
// already earned; Claude phrases them. Everything degrades gracefully when
// the API key / feature flag is absent (the rows simply aren't created).
// ============================================================

// One line of Handler banter — the sardonic rogue-AI voice of the app.
// kind: "daily_rundown" (the day's gigs, generated once/day with the quest
// set), "weekly_debrief" (delivered with the WeeklyReview), or "event"
// (reserved for future reactive lines). Append-only; the ticker reads the
// latest, the Net feed reads the log.
model HandlerMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind      String   // "daily_rundown" | "weekly_debrief" | "event"
  text      String
  persona   String?  // which persona voiced it (for display continuity)
  refType   String?  // "dailyQuestRun" | "weeklyReview" | ...
  refId     String?
  meta      String?  // JSON
  seen      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("handler_messages")
}

// A cross-domain "possible pattern" surfaced from a SERVER-computed
// correlation over the user's own data (sleep↔spend, sleep↔mood, gym↔mood,
// budget drift, neglected contacts). Kept deliberately honest: a minimum
// sample window gates creation, confidence is never stated as causation, and
// the wording is "possible pattern". An insight may carry an allowlisted
// suggested action the user can ACCEPT to spawn a small server-owned quest.
model Insight {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekOf        DateTime?  // the review week it was computed for (null = ad hoc)
  kind          String     // "sleep_spend"|"sleep_mood"|"gym_mood"|"budget"|"social"|"streak"
  title         String
  body          String     // the "possible pattern" narrative
  evidence      String?    // short factual label, e.g. "avg spend 38% higher on <6h-sleep days"
  confidence    String   @default("low")  // "low" | "medium" (small samples never exceed medium)
  windowDays    Int?       // sample window backing it
  suggestion    String?    // the actionable nudge
  // Allowlisted action the user can accept → server spawns a constrained,
  // low-XP quest. "none" = informational only. The XP is server-assigned;
  // the AI never sets it (economy stays server-owned).
  actionType    String   @default("none") // "none"|"reach_out"|"review_budget"|"log_sleep"|"review_spend"
  status        String   @default("new")  // "new"|"accepted"|"dismissed"|"spawned"
  spawnedQuestId String?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("insights")
}

// The weekly after-action report (the "debrief terminal"). Generated once
// per ISO week, lazily, for the PREVIOUS complete week — idempotent via the
// unique (userId, weekOf). statsJson is the server-computed digest; the
// Handler narrates handlerText; the user fills notes + focusForNext and
// SUBMITS (a guarded draft→submitted transition that pays a small fixed
// ritual reward, once).
model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekOf       DateTime // local Monday midnight of the week being reviewed
  statsJson    String   // server-computed digest snapshot (numbers only)
  handlerText  String?  // the Handler's debrief narrative
  status       String   @default("draft") // "draft" | "submitted"
  notes        String?           // manual reflection
  focusForNext String?           // "orders for next cycle"

  generatedAt  DateTime @default(now())
  submittedAt  DateTime?

  @@unique([userId, weekOf])
  @@index([userId, weekOf])
  @@map("weekly_reviews")
}

// ============================================================
// Finance depth (phase 7) — recurring bills & subscription audit.
//
// A tracked recurring money drain ("leech process") distinct from the
// behavioral RecurringList/Habit. Seeded by auto-detection over transaction
// history (source:"detected") and confirmed by the user, or added manually.
// dueDay drives "pay <bill>" reminder quests; the subscription audit lists
// active ones for a keep/cancel pass. No account access — amounts come from
// imported history or are typed.
// ============================================================
model RecurringExpense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  amount      Float                 // typical charge magnitude (positive)
  cadence     String   @default("monthly") // "monthly"|"weekly"|"yearly"
  dueDay      Int?                  // day-of-month the charge lands (monthly)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  active      Boolean  @default(true)
  isSubscription Boolean @default(false) // surfaced in the subscription audit
  source      String   @default("manual") // "manual"|"detected"
  lastPaidOn  DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, active])
  @@map("recurring_expenses")
}